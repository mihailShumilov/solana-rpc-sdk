{
  "name": "solana-resilience-kit",
  "version": "0.1.0",
  "description": "Vendor-neutral, client-side resilience and observability layer for Solana dApps, built on @solana/kit (web3.js v2).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./test/harness/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@solana/kit": "^6.9.0"
  },
  "devDependencies": {
    "@solana-program/system": "^0.12.2",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
