{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": false,
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "jsx": "react-jsx",
    "types": ["node", "react"]
  },
  "include": ["src/react/**/*.ts", "src/react/**/*.tsx"],
  "exclude": ["dist", "node_modules"]
}
